<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nongcetong.nongcetongbackend.mapper.DeviceMapper">

    <resultMap id="DeviceStatusResultMap" type="com.nongcetong.nongcetongbackend.entity.DeviceStatus">
        <id property="id" column="id"/>
        <result property="deviceId" column="device_id"/>
        <result property="deviceName" column="device_name"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="params" column="params"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="DeviceLogResultMap" type="com.nongcetong.nongcetongbackend.entity.DeviceLog">
        <id property="id" column="id"/>
        <result property="deviceId" column="device_id"/>
        <result property="userId" column="user_id"/>
        <result property="action" column="action"/>
        <result property="params" column="params"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByDeviceId" resultMap="DeviceStatusResultMap">
        SELECT * FROM device_status WHERE device_id = #{deviceId}
    </select>

    <update id="updateStatus">
        UPDATE device_status
        SET status = #{status}, params = #{params}, updated_at = NOW()
        WHERE device_id = #{deviceId}
    </update>

    <insert id="insertLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO device_log (device_id, user_id, action, params)
        VALUES (#{deviceId}, #{userId}, #{action}, #{params})
    </insert>

    <select id="findLogsByDeviceId" resultMap="DeviceLogResultMap">
        SELECT * FROM device_log
        WHERE device_id = #{deviceId}
        ORDER BY created_at DESC
            LIMIT #{limit}
    </select>

</mapper>
